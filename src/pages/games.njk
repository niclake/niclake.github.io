---
title: Games
permalink: /games/index.html
---

<p>A catalog of games I'm playing, my favorites, and ones I've completed. This page is powered by data from my <a href="https://howlongtobeat.com/user/niclake/games">HowLongToBeat</a> profile (my preferred game tracking app).</p>

<div class="container card-container">
  {%- if catalog.games.playing.length > 0 %}
    <div class="center-heading">
      <h2>Now Playing</h2>
    </div>
    <div class="row">
      {%- for game in catalog.games.playing %}
        {% include "gameitem.njk" %}
      {%- endfor %}
    </div>
    <hr/>
  {%- endif %}

  {%- if catalog.games.favorites.length > 0 %}
    <div class="center-heading">
      <h2>Favorite Games</h2>
    </div>
    {% set hideMeta = true %}
    <div class="row">
      {%- for game in catalog.games.favorites %}
        {% include "gameitem.njk" %}
      {%- endfor %}
    </div>
    {% set hideMeta = false %}
    <hr/>
  {%- endif %}

  <div class="center-heading">
    <h2>Completed Games</h2>
  </div>

  <p>Games I've completed, grouped by the year I rolled credits. Jump to a year below.</p>

  <div class="catalog-years">
    {% for year in catalog.games.years %}
      <div class="btn-nl-primary">
        <a href="#{{ year.year }}" class="tag-bubble">{{ year.year | replace("y", "") }}</a>{% if not loop.last %} {% endif %}
      </div>
    {% endfor %}
  </div>

  {% set previous_year = "" %}
  {%- for game in catalog.games.datedFinished %}
    {%- set current_year = game.dateFinished | truncate(4, true, '') -%}
    {%- if current_year != previous_year %}
      {% if not loop.first %}</div>{% endif %}
      <div class="center-heading catalog-year">
        <h4 id="y{{ current_year }}">{{ current_year }}</h4>
      </div>
      {% set previous_year = current_year %}
      <div class="row">
    {%- endif %}
    {% include "gameitem.njk" %}
  {%- endfor %}
  {% if catalog.games.datedFinished.length > 0 %}</div>{% endif %}

  {%- if catalog.games.undatedFinished.length > 0 %}
    <div class="center-heading catalog-year">
      <h2 id="undated">Undated</h2>
      <span>Games I've finished that I don't have a completion date for.</span>
    </div>
    <div class="row">
      {%- for game in catalog.games.undatedFinished %}
        {% include "gameitem.njk" %}
      {%- endfor %}
    </div>
  {%- endif %}
</div>
