<div class="container card-container">
  <div class="center-heading">
    <h2 id="current" class="bookyear">Currently Reading</h2>
  </div>
  <div class="row">
    {%- for book in catalog.books.current %}
      {% include "bookitem.njk" %}
    {%- endfor %}
  </div>
  <div class="w-100 mt-1 mb-3">
    <p class="text-center">
      <a href="/catalog/bookshelf">View my bookshelf →</a>
    </p>
  </div>

  {%- if catalog.games.playing.length > 0 %}
    <hr/>
    <div class="center-heading">
      <h2>Currently Playing</h2>
    </div>
    <div class="row">
      {%- for game in catalog.games.playing %}
        {% include "gameitem.njk" %}
      {%- endfor %}
    </div>
    <div class="w-100 mt-1 mb-3">
      <p class="text-center">
        <a href="/catalog/games">View my games →</a>
      </p>
    </div>
  {%- endif %}
</div>
