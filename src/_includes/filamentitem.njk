<div class="col-6 col-lg-3 d-flex align-items-stretch">
  <div class="card catalog-card w-100">
    {% if filament.picture %}
      <div class="position-relative text-center">
        {{ filament.imageHtml | safe }}
        {% if filament.spareSpools and filament.spareSpools != "0" %}
          <span class="badge rounded-pill position-absolute top-0 end-0 m-2 text-white" style="background: rgba(0, 0, 0, 0.55);">+{{ filament.spareSpools }} spare</span>
        {% endif %}
      </div>
    {% endif %}
    <div class="px-2">
      <div>
        <h6 class="mb-0">{{ filament.color }}</h6>
        <span class="text-muted">
          {%- if filament.isBambu %}{{ filament.identifier }}{% else %}{{ filament.brand }}{% if filament.identifier %} {{ filament.identifier }}{% endif %}{% endif -%}
        </span>
      </div>
      {% if filament.activeSpool %}
        <div class="d-flex justify-content-between mt-2">
          <span class="text-muted">Active spool</span>
          <span>{{ filament.activeSpool }}g</span>
        </div>
        <div class="progress" style="height: 4px;" role="progressbar" aria-label="Active spool remaining" aria-valuenow="{{ filament.spoolPct }}" aria-valuemin="0" aria-valuemax="100">
          <div class="progress-bar" style="width: {{ filament.spoolPct }}%; background: {{ filament.barColor }};"></div>
        </div>
      {% endif %}
      {% if filament.url %}
        <div class="text-end pt-1">
          <a href="{{ filament.url }}" target="_blank" rel="noopener">Buy more &nearr;</a>
        </div>
      {% endif %}
    </div>
  </div>
</div>
