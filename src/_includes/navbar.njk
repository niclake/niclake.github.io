<nav class="navbar navbar-expand-xl bg-primary">
  <div class="container">
    <a class="navbar-brand" href="/">
      {% svg "images/site/monogram" %}
      nic lake<span class="me">(me)</span>
    </a>
    <div>
      <button class="navbar-toggler d-xl-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#navOffcanvas" aria-controls="navOffcanvas" aria-expanded="false" aria-label="Toggle navigation">
        <i class="fa-solid fa-bars"></i>
      </button>
    </div>

    <div class="collapse navbar-collapse d-none d-xl-flex" id="navbarSupportedContent">
      <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
        {%- for nav in navigation -%}
          {% if nav.masthead != false %}
            {% if nav.url == page.url %}
              {% set classes = "nav-item active" %}
            {% elif layout == 'post.njk' and nav.text == 'Blog' %}
              {% set classes = "nav-item active" %}
            {% else %}
              {% set classes = "nav-item" %}
            {% endif %}
            <li class="{{ classes }}">
              <a {% if nav.rel %}rel="me"{% endif %} class="nav-link" href="{{ nav.url }}" {% if nav.title %}title="{{ nav.title }}"{% endif %} {% if nav.target %}target="{{ nav.target }}"{% endif %}>
                {{ nav.text | safe }}
              </a>
            </li>
          {% endif %}
        {%- endfor -%}
        <li class="nav-item dropdown">
          <button class="btn btn-link nav-link dropdown-toggle d-flex align-items-center" id="bd-theme" type="button" aria-expanded="false" data-bs-toggle="dropdown" data-bs-display="static" aria-label="Toggle theme">
            <svg class="bi my-1 theme-icon-active" aria-hidden="true">
              <use href="/assets/images/site/moon-stars-fill.svg#moon-stars-fill"></use>
            </svg>
            <span class="d-none ms-2" id="bd-theme-text">Toggle theme</span>
          </button>
          <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="bd-theme-text">
            {% include "_theme-dropdown.njk" %}
          </ul>
        </li>
      </ul>
    </div>

    <div class="offcanvas offcanvas-end d-xl-none" tabindex="-1" id="navOffcanvas" aria-labelledby="navOffcanvasLabel">
      <div class="offcanvas-header">
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="offcanvas" aria-label="Close"></button>
      </div>
      <div class="offcanvas-body">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item dropdown">
            <button class="btn btn-link nav-link dropdown-toggle d-flex align-items-center" type="button" aria-expanded="false" data-bs-toggle="dropdown" data-bs-display="static" aria-label="Toggle theme">
              <svg class="bi my-1 theme-icon-active" aria-hidden="true">
                <use href="/assets/images/site/moon-stars-fill.svg#moon-stars-fill"></use>
              </svg>
              <span class="ms-2" id="bd-theme-text-mobile">Toggle theme</span>
            </button>
            <ul class="dropdown-menu" aria-labelledby="bd-theme-text-mobile">
              {% include "_theme-dropdown.njk" %}
            </ul>
          </li>
          {%- for nav in navigation -%}
            {% if nav.masthead != false and nav.icon != true %}
              {% if nav.url == page.url %}
                {% set classes = "nav-item active" %}
              {% elif layout == 'post.njk' and nav.text == 'Blog' %}
                {% set classes = "nav-item active" %}
              {% else %}
                {% set classes = "nav-item" %}
              {% endif %}
              <li class="{{ classes }}">
                <a {% if nav.rel %}rel="me"{% endif %} class="nav-link" href="{{ nav.url }}" {% if nav.title %}title="{{ nav.title }}"{% endif %} {% if nav.target %}target="{{ nav.target }}"{% endif %}>
                  {{ nav.text | safe }}
                </a>
              </li>
            {% endif %}
          {%- endfor -%}
          <li class="nav-item nav-icons">
            {%- for nav in navigation -%}
              {% if nav.masthead != false and nav.icon == true %}
                <a {% if nav.rel %}rel="me"{% endif %} class="nav-link" href="{{ nav.url }}" {% if nav.title %}title="{{ nav.title }}"{% endif %} {% if nav.target %}target="{{ nav.target }}"{% endif %}>
                  {{ nav.text | safe }}
                </a>
              {% endif %}
            {%- endfor -%}
          </li>
        </ul>
      </div>
    </div>
  </div>
</nav>
